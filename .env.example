# Copy this file to `.env` and fill in. `.env` is git-ignored.
# Generate at: https://account.apple.com → Sign-In and Security → App-Specific Passwords
FASTLANE_APPLE_APPLICATION_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Optional: only needed if your Apple ID belongs to multiple App Store Connect teams
# FASTLANE_ITC_TEAM_ID=
